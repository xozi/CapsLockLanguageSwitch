{
  "version": 3,
  "configurePresets": [
    {
      "name": "x86-Release",
      "displayName": "x86 Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/x86",
      "architecture": {
        "value": "x86",
        "strategy": "external"
